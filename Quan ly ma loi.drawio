          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-55" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="mnCTAhDpj6cvn3uaswME-48" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=default;" target="mnCTAhDpj6cvn3uaswME-51">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-56" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="mnCTAhDpj6cvn3uaswME-48" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=default;" target="mnCTAhDpj6cvn3uaswME-53">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-48" parent="WIyWlLk6GJQsqaUBKTNV-1" style="text;whiteSpace=wrap;html=1;strokeColor=default;" value="&lt;span&gt;&lt;/span&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Kết luận&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="40" width="80" x="1790" y="880" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-58" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="mnCTAhDpj6cvn3uaswME-50" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=default;" target="mnCTAhDpj6cvn3uaswME-57">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-50" parent="WIyWlLk6GJQsqaUBKTNV-1" style="text;whiteSpace=wrap;html=1;strokeColor=default;" value="&lt;span&gt;&lt;/span&gt;&lt;div&gt;&lt;div&gt;Cấu trúc lỗi trả ra: &lt;/div&gt;&lt;div&gt;+ Resonse trả ra gồm các field sau&lt;/div&gt;&lt;div&gt;//Phần quản lý trong DB tập chung&lt;/div&gt;&lt;div&gt;- errorCode :&lt;/div&gt;&lt;div&gt;là các lỗi chung được chia sẻ cho toàn ngân hàng&lt;/div&gt;&lt;div&gt;sẽ có lỗi common chung cho tất cả các kênh (tk thiếu tiền, tk bị khoá)&lt;/div&gt;&lt;div&gt;và lỗi theo từng domain nghiệp vụ&lt;/div&gt;&lt;div&gt;Cố định và phải được approve mới được thêm vào DB (khả thi vì bây giờ hệ thống đã tương đối trưởng thành, các category lỗi gần như không thay đổi/thêm mới nữa)&lt;/div&gt;&lt;div&gt;- errorMessage: Nội dung lỗi, nội dung này lấy trong DB config ra&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;// Phần từng ứng dụng chủ động&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- detailErrorCode :&lt;/span&gt;&lt;/div&gt;&lt;div&gt;chi tiết của lỗi errorCode, nếu là nguồn throw exception thì sẽ đc định nghĩa , miễn là đảm bảo không trùng nhau nếu cùng 1 source&lt;/div&gt;&lt;div&gt;- source : mã hệ thống (có thể là mã của hệ thống to hoặc chi tiết đến MS con  pmp-pex_ms ( có thể có thêm trường sourcename để vận hành dễ trace hơn)&lt;/div&gt;&lt;div&gt;- errorMsg : nội dung lỗi , sẽ mapping theo errorCode hoặc theo detailErrorcode(nếu có)&lt;/div&gt;&lt;div&gt;- errorMetaData: các thông tin bổ sung nếu cần&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="290" width="470" x="1260" y="1000" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-51" parent="WIyWlLk6GJQsqaUBKTNV-1" style="text;whiteSpace=wrap;html=1;strokeColor=default;" value="&lt;span&gt;&lt;/span&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Cách xử lý khi có lỗi:&lt;/div&gt;&lt;div&gt;+ Lỗi phát sinh ở đâu thì source định nghĩa chính xác MS/cấu phần đó&lt;/div&gt;&lt;div&gt;+ Nếu không phải lỗi do mình phát sinh + không xử lý gì thêm thì chỉ fw lại lỗi ra ngoài&lt;/div&gt;&lt;div&gt;+ Cấu phần phát sinh lỗi chỉ được trả ra errorcode chung của toàn ngân hàng hoặc errorcode đã được define cho cấu phần đó&lt;/div&gt;&lt;div&gt;+ Nếu có nhu cầu mapping lại/bổ sung thêm detail code thì source đổi thành nơi phát sinh&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="320" x="1790" y="990" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-60" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="mnCTAhDpj6cvn3uaswME-53" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=default;" target="mnCTAhDpj6cvn3uaswME-59">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-53" parent="WIyWlLk6GJQsqaUBKTNV-1" style="text;whiteSpace=wrap;html=1;strokeColor=default;" value="&lt;span&gt;&lt;/span&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Cách quản lý&lt;/div&gt;&lt;div&gt;+ Tạo 1 DB chung quản lý mã lỗi&lt;/div&gt;&lt;div&gt;+ Errorcode là các lỗi theo cú pháp &amp;lt;DOMAIN-nghiệp vụ&amp;gt;.&amp;lt;CODE&amp;gt;&lt;/div&gt;&lt;div&gt;ACCOUNT.BLOCKED&lt;/div&gt;&lt;div&gt;ACCOUNT.NOT_FOUND&lt;/div&gt;&lt;div&gt;SYSTEM.TIME_OUT&lt;/div&gt;&lt;div&gt;SYSTEM.BUSY&lt;/div&gt;&lt;div&gt;SYSTEM.VALIDATION&lt;/div&gt;&lt;div&gt;Tạm chia thành các DOMAIN:&lt;/div&gt;&lt;div&gt; SYSTEM: các lỗi liên quan đến hệ thống&lt;/div&gt;&lt;div&gt; VALIDATE: các lỗi liên quan đến validate&lt;/div&gt;&lt;div&gt;Nghiệp vụ : Chia theo BIAN&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;đã là common thì không phân biệt hệ thống, dưới góc nhìn của người dùng là như nhau và gần như không thay đổi nữa&lt;/div&gt;&lt;div&gt;+ detailErrorcode quản lý ở bảng khác , quan hệ n detailErrorCode - 1 errorcode&lt;/div&gt;&lt;div&gt;với lỗi validate : có thể là &amp;lt;FIELD&amp;gt;&amp;lt;REASON&amp;gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="560" x="2190" y="1000" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-57" parent="WIyWlLk6GJQsqaUBKTNV-1" style="text;whiteSpace=wrap;html=1;strokeColor=default;" value="&lt;span&gt;&lt;/span&gt;&lt;div&gt;&lt;div&gt;Case thực tế : MS thu chi hộ khi thực hiện thanh toán hoá đơn cho khách hàng, gọi vào MS transfer inhouse -&amp;gt; gọi vào t24 tài khoản truyền vào bị thiếu tiền&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(189, 10, 10);&quot;&gt;+ TH1: dừng luồng luôn&lt;/span&gt;&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;errorCode: ACCOUNT.INSUFFICIENT_AMOUNT&lt;/div&gt;&lt;div&gt;detailErrorCode: Null&lt;/div&gt;&lt;div&gt;source: T24&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;MS inhouse không xử lý gì -&amp;gt; fw ra ngoài -&amp;gt; MS PEX không xử lý gì -&amp;gt; FW ra kênh&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(189, 10, 10);&quot;&gt;+ TH2; trước khi gọi vào T24 để trừ tiền, MS PEX chủ động get ACC để lấy số dư rồi kiểm tra nếu đủ thì mới thực hiện trừ tiền&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Nếu gọi thành công và số dư không đủ : trả lỗi&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;errorCode: ACCOUNT.INSUFFICIENT_AMOUNT&lt;/div&gt;&lt;div&gt;detailErrorCode: có thể có hoặc không&lt;/div&gt;&lt;div&gt;source: PEX&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Nếu gọi check số dư lỗi : timeout hoặc unknow error có trả ra lỗi này ra ngoài không hay mapping?&lt;/div&gt;&lt;div&gt;source = PEX vì đây là nơi lỗi xẩy ra&lt;/div&gt;&lt;div&gt;các cách có thể trả ra&lt;/div&gt;&lt;div&gt;PA1 :{&lt;/div&gt;&lt;div&gt;errorCode: SYSTEM.DEPENDENCY_TIMEOUT&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;-&amp;gt; có thể retry vì chưa phải action write&lt;/div&gt;&lt;div&gt;detailErrorCode: CALL_T24_TIMEOUT ( có thể đặt bộ mã lỗi theo cú pháp &amp;lt;SYSTEM&amp;gt;-002 là gọi vào hệ thống SYSTEM bị timeout và monitor cho các mã detail này&lt;/div&gt;&lt;div&gt;source: PEX&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;hoặc&lt;/div&gt;&lt;div&gt;PA2: {&lt;/div&gt;&lt;div&gt;errorCode: SYSTEM.TIME_OUT&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -&amp;gt; không retry vì đang gọi vào action write&lt;/div&gt;&lt;div&gt;detailErrorCode: CALL_T24_TIMEOUT&amp;nbsp;&lt;/div&gt;&lt;div&gt;source: PEX&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;Đánh giá nên sử dụng :&lt;/div&gt;&lt;div&gt;- PA1 nếu request gặp lỗi TIMEOUT không ở bước quyết định giao dịch có thành công hay không (ở bước gọi ra ngoài để check các đk , lấy các thông tin)&lt;/div&gt;&lt;div&gt;- PA2 nếu request gặp lỗi UNKNOW/TIMEOUT ở bước quyết định nghiệp vụ ấy có thành công hay không (VD ở đây là gọi báo có đối tác hay gọi để trừ tiền)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Trong trường hợp gọi vào T24 thành công nhưng T24 gọi vào core timeout, IL t24 trả ra timeout thì cũng trả ra theo nguyên tắc trên&amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;source: IL_T24,&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(189, 10, 10);&quot;&gt;+ TH3: MS PEX tìm xem KH còn tk khác không thực hiện trên tài khoản khác&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Xử lý tiếp logic và throw ra exception ra ngoài với source = PEX&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="920" width="560" x="1215" y="1440" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-62" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="mnCTAhDpj6cvn3uaswME-59" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=default;" target="mnCTAhDpj6cvn3uaswME-61">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-64" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="mnCTAhDpj6cvn3uaswME-59" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=default;" target="mnCTAhDpj6cvn3uaswME-63">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-72" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="mnCTAhDpj6cvn3uaswME-59" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="mnCTAhDpj6cvn3uaswME-71" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-74" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="mnCTAhDpj6cvn3uaswME-59" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="mnCTAhDpj6cvn3uaswME-73" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-59" parent="WIyWlLk6GJQsqaUBKTNV-1" style="text;whiteSpace=wrap;html=1;strokeColor=default;" value="&lt;span&gt;&lt;/span&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Nguyên tắc thêm mã lỗi:&lt;/div&gt;&lt;div&gt;+ Lỗi ấy có cùng user meaning , đối với khách hàng có coi như là 1 với 1 lỗi đã có không? nếu có thì thêm errorcode, nếu lỗi ấy xuất hiện từ 2 hệ thống trở lên : type COMMON , nếu không type theo CHANNEL , nếu đã có trước đó mà thuộc 1 CHANNEL rồi ?? chuyển lên COMMON ??&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Business error → decision completed&lt;/div&gt;&lt;div&gt;System error&amp;nbsp; &amp;nbsp;→ decision impossible&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;+&amp;nbsp;Error code should describe the REAL reason the operation failed, not the business intention.&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="350" x="1990" y="1340" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-61" parent="WIyWlLk6GJQsqaUBKTNV-1" style="text;whiteSpace=wrap;html=1;strokeColor=default;" value="&lt;span&gt;&lt;/span&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;SYSTEM:&lt;/div&gt;&lt;div&gt;SYSTEM.INTERNAL_ERROR&lt;br class=&quot;soft-break&quot;&gt;SYSTEM.TIMEOUT&lt;/div&gt;&lt;div&gt;SYSTEM.DEPENDENCY_TIMEOUT&lt;br class=&quot;soft-break&quot;&gt;SYSTEM.UNAVAILABLE&lt;br class=&quot;soft-break&quot;&gt;SYSTEM.DEPENDENCY_FAILURE&lt;br class=&quot;soft-break&quot;&gt;SYSTEM.DEPENDENCY_TIMEOUT&lt;br class=&quot;soft-break&quot;&gt;SYSTEM.NETWORK_ERROR&lt;br class=&quot;soft-break&quot;&gt;SYSTEM.DB_TIMEOUT&lt;br class=&quot;soft-break&quot;&gt;SYSTEM.DB_UNAVAILABLE&lt;br class=&quot;soft-break&quot;&gt;SYSTEM.EXTERNAL_TIMEOUT&lt;br class=&quot;soft-break&quot;&gt;SYSTEM.EXTERNAL_UNAVAILABLE&lt;br class=&quot;soft-break&quot;&gt;SYSTEM.RATE_LIMITED&lt;br class=&quot;soft-break&quot;&gt;SYSTEM.CONFIGURATION_ERROR&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="210" width="240" x="1890" y="1640" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-63" parent="WIyWlLk6GJQsqaUBKTNV-1" style="text;whiteSpace=wrap;html=1;strokeColor=default;" value="&lt;span&gt;&lt;/span&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;VALIDATE:&lt;/div&gt;&lt;div&gt;VALIDATION.REQUIRED Missing required field&lt;br class=&quot;soft-break&quot;&gt;VALIDATION.INVALID_FORMAT Wrong format&lt;br class=&quot;soft-break&quot;&gt;VALIDATION.OUT_OF_RANGE Value too small/large&lt;br class=&quot;soft-break&quot;&gt;VALIDATION.NOT_ALLOWED Business rule violation&lt;br class=&quot;soft-break&quot;&gt;VALIDATION.CONFLICT Field conflicts with another&lt;br class=&quot;soft-break&quot;&gt;VALIDATION.UNSUPPORTED Unsupported value&lt;br class=&quot;soft-break&quot;&gt;VALIDATION.LENGTH_INVALID Too short/long&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Tuỳ từng trường hợp có cần trả ra detailError code hay không, nếu không chỉ custom lại cấc message trả ra với các field&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Cách xử lý cho các kênh hiển thị cho người dùng:&lt;/div&gt;&lt;div&gt;Mapping lại các lỗi theo detailErrorCode cho người dùng, với những lỗi phát sinh mà chưa báo lại kênh thì có thể fw message ra cho User (Nếu errorMessage viết bằng tiếng việt thì có thể fw thẳng ra cho User luôn)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;trả ra field bị lỗi trong errorMetadata&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="370" x="2170" y="1640" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-71" parent="WIyWlLk6GJQsqaUBKTNV-1" style="text;whiteSpace=wrap;html=1;strokeColor=default;" value="&lt;span&gt;&lt;/span&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Lỗi nghiệp vụ:&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Chia theo BIAN&lt;/div&gt;&lt;div&gt;ACCOUNT. ...&lt;/div&gt;&lt;div&gt;CUSTOMER.&lt;/div&gt;&lt;div&gt;LOAN.&lt;/div&gt;&lt;div&gt;SAVING.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="270" x="2560" y="1640" as="geometry" />
        </mxCell>
        <mxCell id="mnCTAhDpj6cvn3uaswME-73" parent="WIyWlLk6GJQsqaUBKTNV-1" style="whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=none;gradientColor=none;" value="Lỗi khi gọi đối tác:&lt;div&gt;Bắt buộc phải mapping theo errorCode đã có trong DB hoặc quy về 3 loại lỗi sau&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;SYSTEM.TIMEOUT&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;SYSTEM.DEPENDENCY_TIMEOUT&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;SYSTEM&lt;/span&gt;.UNKNOW_ERROR&lt;/div&gt;&lt;div&gt;detailErrorCode: mã thể hiện đối tác nào&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;PARTNER.ERROR&lt;/div&gt;&lt;div&gt;&lt;div&gt;Chi tiết :có thẻ mapping lại hoặc là mã lỗi do chính đối tác trả về // xem xét thêm&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="250" x="2870" y="1640" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
